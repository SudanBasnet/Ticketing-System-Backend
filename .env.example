NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/ticketing_system
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
CLIENT_RESET_PASSWORD_URL=http://localhost:5173/reset-password
ACCESS_TOKEN_SECRET=replace-with-at-least-32-characters-access-secret
REFRESH_TOKEN_SECRET=replace-with-at-least-32-characters-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Optional email support. If omitted, emails are logged in development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional uploads, reserved for avatars/attachments.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
